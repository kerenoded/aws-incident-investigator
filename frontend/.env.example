# Set this to your API Gateway URL after running `cdk deploy`.
# Copy this file to .env before starting the frontend dev server:
#   cp frontend/.env.example frontend/.env
VITE_API_URL=

# Cognito settings from CDK stack outputs:
# - CognitoRegion
# - CognitoUserPoolClientId
# - ApiCognitoHostedUiDomain (prefix only)
#   Set VITE_COGNITO_DOMAIN to <prefix>.auth.<region>.amazoncognito.com
VITE_COGNITO_REGION=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=

# Redirects must match User Pool app client callback/logout URLs.
# Defaults to window.location.origin if omitted.
VITE_COGNITO_REDIRECT_URI=http://localhost:5173
VITE_COGNITO_LOGOUT_URI=http://localhost:5173
